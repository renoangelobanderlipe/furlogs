{
  "name": "@petlog/root",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently -c \"#93c5fd,#c4b5fd\" \"bun run dev:web\" \"bun run dev:server\" --names=web,server --kill-others",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:server": "composer --working-dir=apps/server dev",
    "build:web": "bun run --cwd apps/web build",
    "lint:web": "bun run --cwd apps/web lint",
    "format:web": "bun run --cwd apps/web format",
    "test:server": "composer --working-dir=apps/server test",
    "install:server": "composer install --working-dir=apps/server",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "husky",
    "knip": "knip"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx,json,css}": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ],
    "apps/server/**/*.php": [
      "./apps/server/vendor/bin/pint"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "1.58.2",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "knip": "^6.0.3",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3"
  }
}
